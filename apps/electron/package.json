{
  "name": "@relax/electron",
  "version": "0.0.1",
  "private": true,
  "productName": "Relax",
  "description": "RELAX desktop app — Electron + Vite + React renderer.",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:all": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false sh -c 'electron-builder --mac --arm64 && electron-builder --mac --x64 && electron-builder --linux && electron-builder --win'",
    "lint": "eslint src --max-warnings=0 || true",
    "test": "echo \"no tests yet\" && exit 0",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "postinstall": "node scripts/patch-electron-name.mjs 2>/dev/null || true"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "mime-types": "^3.0.2",
    "webtorrent": "^3.0.16"
  },
  "build": {
    "appId": "com.relax.app",
    "productName": "Relax",
    "directories": {
      "output": "dist"
    },
    "beforePack": "./scripts/before-pack.cjs",
    "afterAllArtifactBuild": "./scripts/after-all-artifact-build.cjs",
    "files": [
      "out/**/*",
      "!**/.turbo/**",
      "!**/.cache/**",
      "!**/*.map",
      "!**/{tsconfig.json,tsconfig.*.json}",
      "!**/{.eslintrc,.eslintrc.*,.prettierrc,.prettierrc.*}"
    ],
    "extraResources": [
      {
        "from": "resources/icon.icns",
        "to": "icon.icns"
      },
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.entertainment"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "resources/icon.png",
      "category": "AudioVideo"
    }
  },
  "devDependencies": {
    "@connectrpc/connect": "^2.0.1",
    "@connectrpc/connect-web": "^2.0.1",
    "@relax/shared-utils": "workspace:*",
    "@relax/types": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/mime-types": "^3.0.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "lucide-react": "^1.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
