# RELAX backend configuration

# HTTP port for the Connect-RPC server
PORT=8080

# TMDB API key (https://www.themoviedb.org/settings/api) — used by metadata client
TMDB_API_KEY=

# SQLite path or full DSN for the watch-progress / library store
DATABASE_URL=./relax.db

# slog level: debug | info | warn | error
LOG_LEVEL=info

# Allowed CORS origin for the Electron renderer
ALLOWED_ORIGIN=http://localhost:5173

# Set to "production" to switch slog to JSON output
APP_ENV=development
