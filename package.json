{
  "name": "relax",
  "version": "0.0.2",
  "private": true,
  "description": "RELAX — desktop torrent-streaming app for movie geeks.",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "gen:proto": "buf generate",
    "dist": "pnpm gen:proto && pnpm --filter @relax/electron dist",
    "dist:all": "pnpm gen:proto && pnpm --filter @relax/electron dist:all",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.50.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
